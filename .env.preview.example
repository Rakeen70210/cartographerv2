# Copy this file to .env.preview for preview builds.
EXPO_PUBLIC_MAPBOX_ACCESS_TOKEN=pk.your_mapbox_public_token_here
MAPBOX_DOWNLOAD_TOKEN=sk.your_mapbox_download_token_here
EXPO_PUBLIC_ENVIRONMENT=preview
EXPO_PUBLIC_API_URL=https://preview-api.example.com
EXPO_PUBLIC_DEBUG_MODE=false
EXPO_PUBLIC_LOG_LEVEL=info
EXPO_PUBLIC_ENABLE_PERFORMANCE_MONITORING=true
EXPO_PUBLIC_ENABLE_CRASH_REPORTING=true
EXPO_PUBLIC_EXPLORATION_RENDER_SOURCE=areas
